# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Stock photo curation working dirs (Phase 5 Task 4).
# Originals are downloaded from Unsplash/Pexels; processed variants are
# uploaded to Supabase Storage. Neither is committed — they regenerate
# from scripts/stock-photos.json on demand.
/scripts/stock-photos-source/
/scripts/stock-photos-prepared/

# Phase 6 editorial design reference. The claude.ai/design export
# was staged here for visual reference during Phase B (slices 1-7);
# the directory was deleted at the close of Slice 8. The ignore is
# permanent so a future re-import (paste a fresh export to compare
# against the implementation) doesn't accidentally re-commit the
# whole directory. Anything genuinely worth keeping should be
# pulled into docs/design/ instead.
/_design-reference/
